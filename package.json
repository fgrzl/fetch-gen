{
  "name": "@fgrzl/fetch-gen",
  "version": "2.0.0",
  "description": "Generate @fgrzl/fetch clients from OpenAPI spec",
  "keywords": [
    "codegen",
    "fetch",
    "generator",
    "go",
    "openapi"
  ],
  "homepage": "https://github.com/fgrzl/fetch-gen#readme",
  "license": "MIT",
  "author": "smiggleworth",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fgrzl/fetch-gen.git"
  },
  "bin": {
    "fetch-gen": "dist/shim.cjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "import": "./dist/shim.mjs",
    "require": "./dist/shim.cjs"
  },
  "scripts": {
    "build": "vp pack",
    "build:shims": "vp pack",
    "clean": "npx rimraf dist node_modules",
    "test": "vp test",
    "fmt": "vp fmt",
    "lint": "vp lint"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.22"
  }
}
